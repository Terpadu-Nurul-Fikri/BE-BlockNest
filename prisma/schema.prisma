// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// 1. Model Users
model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  firstName    String     @map("first_name") @db.VarChar(100)
  lastName     String?    @map("last_name") @db.VarChar(100)
  phone        String?    @db.VarChar(20)
  role         String?    @default("customer") @db.VarChar(20)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relasi
  cartItems CartItem[]
  orders    Order[]

  @@map("users")
}

// 2. Model Categories
model Category {
  id             String    @id @default(uuid()) @db.Uuid
  slug           String    @unique @db.VarChar(100)
  label          String    @db.VarChar(100)
  headline       String?   @db.VarChar(255)
  description    String?   @db.Text
  seoDescription String?   @map("seo_description") @db.Text
  heroImage      String?   @map("hero_image") @db.Text
  heroAlt        String?   @map("hero_alt") @db.VarChar(255)
  ogImage        String?   @map("og_image") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relasi
  products Product[]

  @@map("categories")
}

// 3. Model Products
model Product {
  id            String    @id @default(uuid()) @db.Uuid
  categoryId    String?   @map("category_id") @db.Uuid
  slug          String    @unique @db.VarChar(255)
  name          String    @db.VarChar(255)
  subCategory   String?   @map("sub_category") @db.VarChar(100)
  price         Decimal   @db.Decimal(12, 2)
  rating        Decimal?  @default(0.00) @db.Decimal(3, 2)
  reviewCount   Int?      @default(0) @map("review_count")
  isNew         Boolean?  @default(false) @map("is_new")
  stockQuantity Int       @default(0) @map("stock_quantity")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relasi
  category   Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images     ProductImage[] // <-- Relasi baru ke banyak gambar
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}



// 3.5 Model Product Images (Menampung banyak foto per produk)
model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  imageUrl  String   @map("image_url") @db.Text
  imageAlt  String?  @map("image_alt") @db.VarChar(255)
  isPrimary Boolean  @default(false) @map("is_primary") // Penanda gambar utama (thumbnail)
  sortOrder Int      @default(0) @map("sort_order")     // Urutan foto (1, 2, 3...)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relasi
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// 4. Model Cart Items
model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relasi
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Constraint kombinasi unik
  @@unique([userId, productId])
  @@map("cart_items")
}

// 5. Model Orders
model Order {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  status          String?  @default("pending") @db.VarChar(50)
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  shippingAddress String   @map("shipping_address") @db.Text
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relasi
  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]
  payments   Payment[]

  @@map("orders")
}

// 6. Model Order Items
model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  quantity    Int
  priceAtTime Decimal  @map("price_at_time") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relasi
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

// 7. Model Payments
model Payment {
  id            String    @id @default(uuid()) @db.Uuid
  orderId       String    @map("order_id") @db.Uuid
  paymentMethod String    @map("payment_method") @db.VarChar(50)
  paymentStatus String?   @default("pending") @map("payment_status") @db.VarChar(50)
  transactionId String?   @unique @map("transaction_id") @db.VarChar(255)
  amount        Decimal   @db.Decimal(12, 2)
  paidAt        DateTime? @map("paid_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relasi
  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@map("payments")
}


// 8. Model Banners / Announcements (Untuk Iklan & Pengumuman)
model Banner {
  id        String    @id @default(uuid()) @db.Uuid
  title     String    @db.VarChar(255) // Nama internal (contoh: "Promo Lebaran 2026")
  type      String    @db.VarChar(50)  // Posisi di UI: 'top_bar', 'hero_slider', 'popup'
  imageUrl  String?   @map("image_url") @db.Text // Opsional, jika iklannya berupa gambar
  imageAlt  String?   @map("image_alt") @db.VarChar(255)
  content   String?   @db.Text         // Teks pengumuman ("Free shipping over $500!")
  linkUrl   String?   @map("link_url") @db.Text // URL tujuan saat iklan diklik (contoh: "/sale")
  
  // Kontrol Penayangan
  isActive  Boolean   @default(true) @map("is_active") // Tombol on/off manual
  startDate DateTime? @map("start_date") @db.Timestamptz // Kapan iklan otomatis tayang
  endDate   DateTime? @map("end_date") @db.Timestamptz   // Kapan iklan otomatis turun
  
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("banners")
}